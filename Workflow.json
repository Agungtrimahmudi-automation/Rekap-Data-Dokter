    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || {};\nconst bulan = body.bulan || '';\nconst fileUrls = body.fileUrls || [];\nconst email = body.email || body['Email Address'] || '';\n\nif (!bulan || !/^\\d{2}\\/\\d{4}$/.test(bulan)) {\n  throw new Error('Field \"bulan\" wajib format MM/YYYY. Diterima: ' + JSON.stringify(bulan));\n}\nif (!Array.isArray(fileUrls) || fileUrls.length < 3) {\n  throw new Error('Field \"fileUrls\" wajib array berisi 3 link: [rawat_inap, poli, icu]');\n}\n\nconst [bulanNum, tahun] = bulan.split('/');\nconst bulanNames = ['JANUARI','FEBRUARI','MARET','APRIL','MEI','JUNI','JULI','AGUSTUS','SEPTEMBER','OKTOBER','NOVEMBER','DESEMBER'];\nconst idx = parseInt(bulanNum, 10) - 1;\nif (idx < 0 || idx > 11) {\n  throw new Error('Bulan tidak valid: ' + bulanNum);\n}\nconst sheetName = bulanNames[idx];\n\nfunction extractFileId(url) {\n  if (!url) return null;\n  let m = String(url).match(/\\/d\\/([a-zA-Z0-9_-]+)/);\n  if (m) return m[1];\n  m = String(url).match(/[?&]id=([a-zA-Z0-9_-]+)/);\n  if (m) return m[1];\n  return null;\n}\n\nconst fileTypes = ['rawat-inap', 'poli', 'icu'];\nconst items = [];\n\nfor (let i = 0; i < 3; i++) {\n  const fileId = extractFileId(fileUrls[i]);\n  if (!fileId) {\n    throw new Error('Tidak bisa mengekstrak fileId dari link untuk \"' + fileTypes[i] + '\": ' + fileUrls[i]);\n  }\n  items.push({\n    json: {\n      fileType: fileTypes[i],\n      fileId: fileId,\n      sheetName: sheetName,\n      bulan: bulan,\n      email: email\n    }\n  });\n}\n\nreturn items;"
      },
