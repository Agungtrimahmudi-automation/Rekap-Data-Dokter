      "id": "Merge-RI-Poli-ICU-ID",
      "name": "Merge"
    },
    {
      "parameters": {
        "jsCode": "const triggerData = $('Webhook Trigger').first().json.body;\nconst bulan = triggerData.bulan;\nconst email = triggerData.email || '';\n\nconst [targetMonthStr, targetYearStr] = bulan.split('/');\nconst targetMonth = parseInt(targetMonthStr, 10);\nconst targetYear = parseInt(targetYearStr, 10);\n\nfunction getDaysInMonth(month, year) {\n  return new Date(Date.UTC(year, month, 0)).getDate();\n}\nconst totalDays = getDaysInMonth(targetMonth, targetYear);\n\nfunction formatDate(day, month, year) {\n  return month + '/' + day + '/' + year;\n}\n\nconst allDates = [];\nfor (let d = 1; d <= totalDays; d++) {\n  allDates.push(formatDate(d, targetMonth, targetYear));\n}\n\nconst dokterMap = {\n  dokter_a:   { nik: 'NIK_PLACEHOLDER', nama: 'dr. A Sp.PD' },\n  dokter_b: { nik: 'NIK_PLACEHOLDER', nama: 'dr. B, Sp.PD' },\n  dokter_c:   { nik: 'NIK_PLACEHOLDER', nama: 'dr. C Sp.PK' },\n  dokter_d:   { nik: 'NIK_PLACEHOLDER', nama: 'dr. D Sp.GK' }\n};\nconst dokterKeys = Object.keys(dokterMap);\n\nfunction normalize(s) {\n  return String(s || '').toLowerCase().replace(/[^a-z0-9]/g, '');\n}\nfunction matchDokter(namaRaw) {\n  const n = normalize(namaRaw);\n  if (n.includes('dokter_a')) return 'dokter_a';\n  if (n.includes('dokter_b')) return 'dokter_b';\n  if (n.includes('dokter_c')) return 'dokter_c';\n  if (n.includes('dokter_d')) return 'dokter_d';\n  return null;\n}\n\nconst counts = {};\nfor (const dKey of dokterKeys) {\n  counts[dKey] = {};\n  for (const tgl of allDates) {\n    counts[dKey][tgl] = 0;\n  }\n}\n\nfor (const item of $input.all()) {\n  const namaDokterRaw = item.json.namaDokterRaw;\n  const tanggal = item.json.tanggal;\n  const dokterKey = matchDokter(namaDokterRaw);\n  if (dokterKey && counts[dokterKey] && counts[dokterKey][tanggal] !== undefined) {\n    counts[dokterKey][tanggal] += 1;\n  }\n}\n\nconst output = [];\nfor (const dKey of dokterKeys) {\n  const sortedDates = allDates.slice().sort((a, b) => {\n    const [m1, d1, y1] = a.split('/').map(Number);\n    const [m2, d2, y2] = b.split('/').map(Number);\n    return new Date(Date.UTC(y1, m1-1, d1)) - new Date(Date.UTC(y2, m2-1, d2));\n  });\n\n  let no = 1;\n  for (const tgl of sortedDates) {\n    const jumlah = counts[dKey][tgl] || 0;\n    output.push({\n      json: {\n        dokterKey: dKey,\n        no: no++,\n        nikDokter: dokterMap[dKey].nik,\n        namaDokter: dokterMap[dKey].nama,\n        tanggalPelayanan: tgl,\n        jumlahPasien: jumlah,\n        jumlahBacaanPenunjang: jumlah,\n        email: email\n      }\n    });\n  }\n}\n\nreturn output;"
      },
