    {
      "parameters": {
        "jsCode": "const bulan = $('Webhook Trigger').first().json.body.bulan;\nconst [targetMonthStr, targetYearStr] = bulan.split('/');\nconst targetMonth = parseInt(targetMonthStr, 10);\nconst targetYear = parseInt(targetYearStr, 10);\n\nfunction parseTanggal(v) {\n  if (!v) return null;\n  const raw = String(v).trim();\n  if (/^\\d+(\\.\\d+)?$/.test(raw) && Number(raw) > 1000) {\n    const utcMs = Math.round((Number(raw) - 25569) * 86400 * 1000);\n    return new Date(utcMs);\n  }\n  const parts = raw.split(/[\\/\\-]/);\n  if (parts.length !== 3) return null;\n  let mm = parseInt(parts[0], 10);\n  let dd = parseInt(parts[1], 10);\n  let yy = parseInt(parts[2], 10);\n  if (isNaN(mm) || isNaN(dd) || isNaN(yy)) return null;\n  if (yy < 100) yy = yy + (yy < 50 ? 2000 : 1900);\n  if (mm < 1 || mm > 12) return null;\n  return new Date(Date.UTC(yy, mm - 1, dd));\n}\n\nfunction formatTanggal(d) {\n  return (d.getUTCMonth() + 1) + '/' + d.getUTCDate() + '/' + d.getUTCFullYear();\n}\n\nfunction addDays(d, n) {\n  const nd = new Date(d);\n  nd.setUTCDate(nd.getUTCDate() + n);\n  return nd;\n}\n\nfunction isInTargetMonth(d) {\n  return d.getUTCMonth() + 1 === targetMonth && d.getUTCFullYear() === targetYear;\n}\n\nconst output = [];\nfor (const item of $input.all()) {\n  const row = item.json;\n  const namaDokterRaw = row['NAMA DOKTER'];\n  const masuk = parseTanggal(row['TGL MASUK']);\n  const keluar = parseTanggal(row['TGL KELUAR']);\n  if (!namaDokterRaw || !masuk || !keluar) continue;\n  let cursor = masuk;\n  const end = keluar.getTime() >= masuk.getTime() ? keluar : masuk;\n  while (cursor.getTime() <= end.getTime()) {\n    if (isInTargetMonth(cursor)) {\n      output.push({\n        json: {\n          namaDokterRaw: namaDokterRaw,\n          tanggal: formatTanggal(cursor)\n        }\n      });\n    }\n    cursor = addDays(cursor, 1);\n  }\n}\nreturn output;"
      },
